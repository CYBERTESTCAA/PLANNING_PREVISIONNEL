        <mxCell id="t_warehouse" value="&lt;b&gt;Warehouse&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;WH_OR_GROUPE_CAA&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Tables structurées&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#1B5E20;fontColor=#FFFFFF;strokeColor=#1B5E20;shadow=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="840" y="440" width="160" height="130" as="geometry" />
        </mxCell>

        <!-- ============================================ -->
        <!-- VM POSTGRESQL (NOUVEAU !) -->
        <!-- ============================================ -->
        <mxCell id="t_zone_vm" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=3;dashed=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1130" y="250" width="300" height="370" as="geometry" />
        </mxCell>
        <mxCell id="t_zone_vm_label" value="&lt;b&gt;🖥️ VM Dédiée (NOUVELLE)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1170" y="258" width="210" height="30" as="geometry" />
        </mxCell>

        <!-- PostgreSQL -->
        <mxCell id="t_postgres" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;BDD centralisée&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;• Relations entre tables&lt;br&gt;• Tables supplémentaires&lt;br&gt;• Vue unifiée des données&lt;br&gt;• Remplace Warehouse comme&lt;br&gt;&amp;nbsp; source pour l'app + BI&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#E65100;fontColor=#FFFFFF;strokeColor=#BF360C;shadow=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1175" y="310" width="210" height="180" as="geometry" />
        </mxCell>

        <!-- Script sync -->
        <mxCell id="t_sync_script" value="&lt;b&gt;Script de Sync&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Exécuté toutes les &lt;b&gt;12h&lt;/b&gt;&lt;br&gt;(cron / systemd timer)&lt;br&gt;Warehouse → PostgreSQL&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF6F00;fontColor=#FFFFFF;strokeColor=#E65100;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1190" y="520" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- ============================================ -->
        <!-- SORTIES depuis PostgreSQL -->
        <!-- ============================================ -->

        <!-- Rapports Power BI -->
        <mxCell id="t_zone_bi" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;dashed=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="680" width="340" height="260" as="geometry" />
        </mxCell>
        <mxCell id="t_zone_bi_label" value="&lt;b&gt;Power BI&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#7B1FA2;" vertex="1" parent="1">
          <mxGeometry x="330" y="685" width="90" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t_semantic" value="&lt;b&gt;Modèle&lt;br&gt;Sémantique&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Dataset lié à&lt;br&gt;&lt;b&gt;PostgreSQL&lt;/b&gt; (Direct Query&lt;br&gt;ou Import)&lt;/font&gt;" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;size=18;fillColor=#9C27B0;fontColor=#FFFFFF;strokeColor=#6A1B9A;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="245" y="720" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t_reports" value="&lt;b&gt;Rapports&lt;br&gt;Power BI&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Tableaux de bord&lt;/font&gt;" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.15;fillColor=#CE93D8;fontColor=#4A148C;strokeColor=#7B1FA2;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="845" width="130" height="80" as="geometry" />
        </mxCell>

        <!-- App Suivi de Chantiers -->
        <mxCell id="t_zone_app" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;dashed=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="680" width="340" height="260" as="geometry" />
        </mxCell>
        <mxCell id="t_zone_app_label" value="&lt;b&gt;App Suivi de Chantiers&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="745" y="685" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t_app_api" value="&lt;b&gt;API Fastify&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Se connecte à&lt;br&gt;&lt;b&gt;PostgreSQL&lt;/b&gt; au lieu&lt;br&gt;de SQLite&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;fontColor=#FFFFFF;strokeColor=#1B5E20;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="730" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t_app_web" value="&lt;b&gt;Frontend React&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Identique (SPA)&lt;br&gt;Planning, Gantt,&lt;br&gt;Questions, Plans…&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#43A047;fontColor=#FFFFFF;strokeColor=#2E7D32;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="840" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- ============================================ -->
        <!-- FLÈCHES — partie Fabric (identique) -->
        <!-- ============================================ -->

        <!-- HK → Gateway -->
        <mxCell id="t_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#E65100;" edge="1" source="t_hk_bdd" target="t_gateway" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t_a1_l" value="&lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;Données brutes&lt;/b&gt;&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="t_a1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- Gateway → Gen2 -->
        <mxCell id="t_a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#7B1FA2;" edge="1" source="t_gateway" target="t_gen2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Gen2 → Lakehouse -->
        <mxCell id="t_a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#1565C0;" edge="1" source="t_gen2" target="t_lakehouse" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t_a3_l" value="&lt;font color=&quot;#1565C0&quot;&gt;&lt;b&gt;En vrac&lt;/b&gt;&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="t_a3">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- Lakehouse → Pipeline -->
        <mxCell id="t_a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#00838F;" edge="1" source="t_lakehouse" target="t_pipeline" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Pipeline → Warehouse -->
        <mxCell id="t_a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#1B5E20;" edge="1" source="t_pipeline" target="t_warehouse" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t_a5_l" value="&lt;font color=&quot;#1B5E20&quot;&gt;&lt;b&gt;Structuré&lt;/b&gt;&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="t_a5">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ============================================ -->
        <!-- FLÈCHES — nouvelles (Warehouse ↔ PostgreSQL) -->
        <!-- ============================================ -->

        <!-- Warehouse → Script sync -->
        <mxCell id="t_a6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=4;strokeColor=#E65100;flowAnimation=1;" edge="1" source="t_warehouse" target="t_sync_script" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1090" y="505" />
              <mxPoint x="1090" y="560" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="t_a6_l" value="&lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;Lecture SQL&lt;br&gt;(toutes les 12h)&lt;/b&gt;&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="t_a6">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- Script sync → PostgreSQL -->
        <mxCell id="t_a7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#E65100;" edge="1" source="t_sync_script" target="t_postgres" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t_a7_l" value="&lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;Upsert&lt;/b&gt;&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="t_a7">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ============================================ -->
        <!-- FLÈCHES — PostgreSQL → consommateurs -->
        <!-- ============================================ -->

        <!-- PostgreSQL → Power BI -->
        <mxCell id="t_a8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#9C27B0;flowAnimation=1;" edge="1" source="t_postgres" target="t_semantic" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1280" y="680" />
              <mxPoint x="500" y="680" />
              <mxPoint x="500" y="770" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="t_a8_l" value="&lt;font color=&quot;#9C27B0&quot;&gt;&lt;b&gt;Connexion PostgreSQL&lt;br&gt;(Direct Query ou Import)&lt;/b&gt;&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="t_a8">
          <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- Modèle sémantique → Rapports -->
        <mxCell id="t_a9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#7B1FA2;" edge="1" source="t_semantic" target="t_reports" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- PostgreSQL → App API -->
        <mxCell id="t_a10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#2E7D32;flowAnimation=1;" edge="1" source="t_postgres" target="t_app_api" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1280" y="660" />
              <mxPoint x="800" y="660" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="t_a10_l" value="&lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;Connexion PostgreSQL&lt;br&gt;(Prisma ou pg driver)&lt;/b&gt;&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=11;labelBackgroundColor=#FFFFFF;" vertex="1" connectable="0" parent="t_a10">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- App API → Frontend -->
        <mxCell id="t_a11" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" source="t_app_api" target="t_app_web" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================ -->
        <!-- ANNOTATIONS / AVANTAGES -->
        <!-- ============================================ -->
        <mxCell id="t_note" value="&lt;b&gt;✅ Avantages de cette architecture :&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;Relations entre tables&lt;/b&gt; : clés étrangères, contraintes,&lt;br&gt;&amp;nbsp; index — impossible dans le Warehouse Fabric&lt;br&gt;• &lt;b&gt;Tables supplémentaires&lt;/b&gt; : planning, affectations,&lt;br&gt;&amp;nbsp; questions, plans… directement dans PostgreSQL&lt;br&gt;• &lt;b&gt;Source unique&lt;/b&gt; : l'app ET les rapports BI pointent&lt;br&gt;&amp;nbsp; sur la même base → cohérence des données&lt;br&gt;• &lt;b&gt;Performance&lt;/b&gt; : PostgreSQL est beaucoup plus rapide&lt;br&gt;&amp;nbsp; que les requêtes SQL vers Fabric&lt;br&gt;• &lt;b&gt;Indépendance&lt;/b&gt; : si Fabric est en panne, l'app&lt;br&gt;&amp;nbsp; continue de fonctionner (dernière sync)&lt;br&gt;• &lt;b&gt;Coût&lt;/b&gt; : moins de requêtes vers Fabric = moins cher" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=20;fillColor=#FFFDE7;strokeColor=#F57F17;shadow=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1130" y="680" width="330" height="310" as="geometry" />
        </mxCell>

        <!-- ============================================ -->
        <!-- BARRÉ : ancien lien direct Warehouse → App -->
        <!-- ============================================ -->
        <mxCell id="t_old" value="&lt;font color=&quot;#D32F2F&quot;&gt;&lt;b&gt;❌ ANCIEN : Warehouse → SQLite&lt;br&gt;(supprimé)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="810" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t_old2" value="&lt;font color=&quot;#D32F2F&quot;&gt;&lt;b&gt;❌ ANCIEN : Warehouse → BI direct&lt;br&gt;(supprimé)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="850" width="210" height="40" as="geometry" />
        </mxCell>

        <!-- ============================================ -->
        <!-- LÉGENDE -->
        <!-- ============================================ -->
        <mxCell id="t_legend" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="910" width="700" height="60" as="geometry" />
        </mxCell>
        <mxCell id="t_legend_text" value="&lt;b&gt;Légende :&lt;/b&gt;  🟠 Source HK → 🟣 Gateway → 🔵 Fabric (inchangé) → 🟠 &lt;b&gt;VM PostgreSQL&lt;/b&gt; (NOUVEAU) → 🟣 Rapports BI  +  🟢 App Suivi de Chantiers" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#424242;" vertex="1" parent="1">
          <mxGeometry x="55" y="925" width="720" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
