# SQLite database file (local, WAL mode applied at startup)
DATABASE_URL="file:./planning.sqlite"

# Server
PORT=3001
HOST=0.0.0.0

# Fabric Warehouse (Power BI Premium) — pour la synchronisation des données
FABRIC_SQL_ENDPOINT="votre-endpoint.datawarehouse.fabric.microsoft.com"
FABRIC_DATABASE="WH_OR_GROUPE_CAA"
FABRIC_TENANT_ID="55981225-247f-4ff6-8678-e1efb27d133e"
FABRIC_CLIENT_ID="votre-client-id"
FABRIC_CLIENT_SECRET="votre-client-secret"

# Fréquence de synchro automatique (format cron, défaut : toutes les heures)
FABRIC_SYNC_CRON="0 * * * *"

# Azure AD Authentication (pour protéger les écritures)
AZURE_AD_TENANT_ID="55981225-247f-4ff6-8678-e1efb27d133e"
AZURE_AD_CLIENT_ID="votre-app-registration-client-id"
AZURE_AD_GROUP_ID="bd3a6f77-0a07-4ade-a2e5-d26cd8310297"
