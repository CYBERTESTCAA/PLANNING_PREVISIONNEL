[Unit]
Description=Planning Previsionnel API
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/planning_previsionnel/current/api
EnvironmentFile=/opt/planning_previsionnel/shared/api.env
ExecStart=/usr/bin/node /opt/planning_previsionnel/current/api/dist/index.js
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
